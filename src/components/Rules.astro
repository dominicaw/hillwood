---
import { ruleSections, rulesMeta } from "../data/rules";
---

<section id="rules" class="rules">
	<div class="section-inner">
		<p class="section-label">Body Corporate</p>
		<h2>{rulesMeta.title}</h2>
		<p class="rules-meta">{rulesMeta.subtitle}</p>
		<p class="rules-issued">Issued {rulesMeta.issued}</p>

		<button type="button" class="rules-download" id="download-rules-pdf">
			Download as PDF
		</button>

		<div class="rules-list">
			{
				ruleSections.map((section) => (
					<details id={`rule-${section.id}`} class="rule-item">
						<summary>
							<span class="rule-number">{section.number}.</span>
							{section.title}
						</summary>
						<div class="rule-content">
							<ol>
								{section.items.map((item) => (
									<li>{item}</li>
								))}
							</ol>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>

<script>
	import { downloadRulesPdf } from "../scripts/downloadRulesPdf";

	document.getElementById("download-rules-pdf")?.addEventListener("click", downloadRulesPdf);
</script>

<style>
	.rules-meta {
		color: var(--color-text-muted);
		font-size: 0.9375rem;
		margin-bottom: 0.25rem;
	}

	.rules-issued {
		color: var(--color-text-muted);
		font-size: 0.875rem;
		margin-bottom: 1.25rem;
	}

	.rules-download {
		display: inline-block;
		margin-bottom: 2rem;
		padding: 0.75rem 1.5rem;
		font-family: inherit;
		font-weight: 600;
		font-size: 0.9375rem;
		color: #fff;
		background: var(--color-accent);
		border: none;
		border-radius: 4px;
		cursor: pointer;
		transition: background 0.15s ease;
	}

	.rules-download:hover,
	.rules-download:focus-visible {
		background: var(--color-accent-hover);
	}

	.rules-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.rule-item {
		border: 1px solid var(--color-border);
		border-radius: 6px;
		overflow: hidden;
		scroll-margin-top: calc(var(--header-height) + 1rem);
	}

	.rule-item summary {
		padding: 1rem 1.25rem;
		font-weight: 600;
		cursor: pointer;
		list-style: none;
	}

	.rule-item summary::-webkit-details-marker {
		display: none;
	}

	.rule-item summary::after {
		content: "+";
		float: right;
		font-weight: 400;
		color: var(--color-accent);
	}

	.rule-item[open] summary::after {
		content: "−";
	}

	.rule-item summary:hover {
		background: var(--color-hover-surface);
	}

	.rule-number {
		color: var(--color-text-muted);
		margin-right: 0.25rem;
	}

	.rule-content {
		padding: 0 1.25rem 1.25rem;
		border-top: 1px solid var(--color-border);
	}

	.rule-content ol {
		margin: 1rem 0 0;
		padding-left: 1.25rem;
	}

	.rule-content li {
		color: var(--color-text);
	}
</style>
