---
import hillwoodGif from "../assets/hillwood-transparent.gif";
---

<section id="home" class="hero">
	<div class="section-inner">
		<div class="hero-content">
			<h1 class="hero-title">Hillwood</h1>
			<p class="section-label">58 Galway Road, Heathfield, Cape Town</p>
			<p class="hero-tagline">
				Established in 1989, Hillwood is a friendly community in the heart of Heathfield, Cape Town.
			</p>
		</div>
		<img
			class="hero-art"
			src={hillwoodGif.src}
			alt=""
			width={400}
			height={256}
			aria-hidden="true"
		/>
	</div>
</section>

<style>
	.hero {
		padding-top: 1rem;
	}

	.hero .section-inner {
		position: relative;
		background-color: #bfd2dd;
	}

	.hero-content {
		position: relative;
		z-index: 1;
	}

	.hero-art {
		position: absolute;
		right: 0;
		bottom: 0;
		width: 200px;
		height: auto;
		image-rendering: pixelated;
		image-rendering: crisp-edges;
		pointer-events: none;
	}

	.hero-title {
		margin: 0rem;
	}

	.hero-tagline {
		max-width: 30rem;
		color: var(--color-text-muted);
		margin-bottom: 2rem;
	}

	@media (max-width: 768px) {
		.hero-tagline {
			max-width: 20rem;
		}
	}

	@media (max-width: 480px) {
		.hero-tagline {
			max-width: 10rem;
		}
	}

	.hero-cta {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		font-weight: 600;
		font-size: 0.9375rem;
		color: #fff;
		background: var(--color-accent);
		border-radius: 4px;
		text-decoration: none;
		transition: background 0.15s ease;
	}

	.hero-cta:hover,
	.hero-cta:focus-visible {
		background: var(--color-accent-hover);
		color: #fff;
	}
</style>
